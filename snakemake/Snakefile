#####################
### Load functions ###
#####################

# 1. Liste simple des IDs d'échantillons
SAMPLES = list(config["samples"].keys())

# 2. LA FONCTION CRUCIALE : Elle traduit l'ID court en chemin long du serveur
def get_raw_fastq(wildcards):
    # Va chercher la valeur dans le config.json (ex: "NS133.../MonFichier")
    file_prefix = config["samples"][wildcards.sample]
    return {
        "r1": f"{DataPath}/{file_prefix}_R1_001.fastq.gz",
        "r2": f"{DataPath}/{file_prefix}_R2_001.fastq.gz"
    }

# 3. Liste pour MultiQC
def get_files_for_multiqc(wildcards):
    files = []
    for s in SAMPLES:
        files.append(f"{Workdir}/FastQC/fastqc_raw/{s}/{s}_R1_001_fastqc.zip")
        files.append(f"{Workdir}/FastQC/fastqc_raw/{s}/{s}_R2_001_fastqc.zip")
        files.append(f"{Workdir}/logs/trimmomatic/err_trimmomatic_{s}.txt")
    return files

