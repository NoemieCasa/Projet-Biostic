# 1. Liste simple des IDs d'échantillons (ex: HV_01_01)
SAMPLES = list(config["samples"].keys())

# 2. Fonction de correspondance pour trouver les fichiers BRUTS (Fastq de départ)
# Elle fait le pont entre "HV_01_01" et le chemin long dans /LAB-DATA/
def get_raw_fastq(wildcards):
    # Récupère le préfixe du fichier depuis le config
    file_prefix = config["samples"][wildcards.sample]
    r1 = f"{DataPath}/{file_prefix}_R1_001.fastq.gz"
    r2 = f"{DataPath}/{file_prefix}_R2_001.fastq.gz"
    return {"r1": r1, "r2": r2}

# 3. Liste des fichiers pour MultiQC (FastQC et Trimmomatic)
# On utilise expand() pour générer automatiquement la liste pour TOUS les échantillons
def get_files_for_multiqc(wildcards):
    files = []
    for s in SAMPLES:
        # On ajoute les zips de FastQC (ceux définis dans tes règles)
        files.append(f"{Workdir}/FastQC/fastqc_raw/{s}/{config['samples'][s]}_R1_001_fastqc.zip")
        files.append(f"{Workdir}/FastQC/fastqc_raw/{s}/{config['samples'][s]}_R2_001_fastqc.zip")
        # On ajoute les logs de Trimmomatic
        files.append(f"{Workdir}/logs/trimmomatic/err_trimmomatic_{s}.txt")
    return files

# 4. Liste des fichiers FASTA pour l'indexation du génome
FastaFileDir = config["fastafiledir"]
FastaFiles = [f"{FastaFileDir}/{f}" for f in config["fastafiles"].values()]

# 5. Fonctions pour Trinity (Concaténation par virgules pour tous les samples)
def get_all_trimmed_r1(wildcards):
    return ",".join(expand(f"{Workdir}/Trimming/{{sample}}_R1_001_paired.fastq.gz", sample=SAMPLES))

def get_all_trimmed_r2(wildcards):
    return ",".join(expand(f"{Workdir}/Trimming/{{sample}}_R2_001_paired.fastq.gz", sample=SAMPLES))


