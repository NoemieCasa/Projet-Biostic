# 1. On définit le chemin vers TON installation micromamba
MAMBA_ROOT = "/home/iguerin2024@ec-nantes.fr/micromamba"

# 2. On configure le shell pour Nautilus
shell.executable("/bin/bash")

# 3. Le préfixe magique : il définit la racine ET active le hook micromamba
shell.prefix(
    f"set -o pipefail; "
    f"export MAMBA_ROOT_PREFIX={MAMBA_ROOT}; "
    f"eval \"$({MAMBA_ROOT}/bin/micromamba shell hook -s bash)\"; "
)

